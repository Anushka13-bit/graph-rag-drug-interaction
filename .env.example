NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_password
NEO4J_DATABASE=neo4j

OPENAI_API_KEY=
USE_OPENAI=false

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral

